  <diagram id="rbl-research-flow" name="Research Data Collection Flow">
    <mxGraphModel dx="1471" dy="803" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="2600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fillColor=#1a237e;fontColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;fontStyle=1;strokeColor=none;" value="SEAL HACKATHON — RESEARCH DATA COLLECTION FLOW&#xa;Thu thập dữ liệu nghiên cứu độ tin cậy liên đánh giá viên (ICC / Krippendorff&#39;s α)&#xa;FPT University TP.HCM — SE Department" vertex="1">
