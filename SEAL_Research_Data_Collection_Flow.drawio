        <mxCell id="b8-c" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="📄 Dataset C — Appeal Log&#xa;Appeal_ID | Sub_ID | Criteria | Old_Score | New_Score | Judge_Type | Decision | Timestamp" vertex="1">
