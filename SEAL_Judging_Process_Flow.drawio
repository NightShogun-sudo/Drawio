        <mxCell id="title" parent="1" style="text;html=1;fillColor=#1b5e20;fontColor=#ffffff;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;fontStyle=1;strokeColor=none;" value="SEAL HACKATHON — JUDGING PROCESS FLOW&#xa;Quy trình chấm điểm: Hiệu chuẩn → Chấm chính thức → Kiểm soát phương sai → Xếp hạng&#xa;FPT University TP.HCM — SE Department" vertex="1">
