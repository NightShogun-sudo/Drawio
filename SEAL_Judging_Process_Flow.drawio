        <mxCell id="lg5" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="Data / Output" vertex="1">
          <mxGeometry height="35" width="130" x="615" y="125" as="geometry" />
        </mxCell>
        <mxCell id="lg-txt" parent="1" style="text;html=1;fillColor=none;strokeColor=none;align=left;fontSize=10;fontStyle=1;" value="ACTORS: 🤖 System  |  👨‍💼 Coordinator  |  ⚖ Judge  |  👔 Dept Head" vertex="1">
          <mxGeometry height="30" width="560" x="780" y="130" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" value="🚀 START" vertex="1">
          <mxGeometry height="55" width="200" x="600" y="205" as="geometry" />
        </mxCell>
        <mxCell id="b1" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" value="B1 — 👨‍💼 Setup Criteria / Assign Judge&#xa;• Criteria Template (Dept Head APPROVED): tên + trọng số + rubric 5 mức&#xa;• Tiêu chí: Innovation 25% | Technical 30% | Business 20% | Presentation 15% | Teamwork 10%&#xa;• Assign ≥ 3 judges/vòng/hạng mục | Judge ≠ Mentor cùng hạng mục" vertex="1">
          <mxGeometry height="105" width="620" x="390" y="290" as="geometry" />
        </mxCell>
        <mxCell id="b2-gate" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" value="B2 — ⚠ Validate&#xa;Conditions&#xa;&#xa;✓ Criteria sum = 100%?&#xa;✓ ≥ 3 judges assigned?&#xa;✓ No COI (Judge=Mentor)?&#xa;✓ Template = PUBLISHED?" vertex="1">
          <mxGeometry height="155" width="290" x="555" y="435" as="geometry" />
        </mxCell>
        <mxCell id="fix-box" parent="1" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="👨‍💼 Coordinator chỉnh sửa&#xa;• Điều chỉnh trọng số&#xa;• Thêm / đổi judge&#xa;• Cập nhật template" vertex="1">
          <mxGeometry height="80" width="250" x="100" y="480" as="geometry" />
        </mxCell>
        <mxCell id="b3-label" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=12;fontStyle=1;align=center;fontColor=#b71c1c;" value="━━━━━━━━━━━━━━━━  CALIBRATION SESSION (1–2 ngày trước chấm chính thức)  ━━━━━━━━━━━━━━━━" vertex="1">
          <mxGeometry height="25" width="1240" x="80" y="625" as="geometry" />
        </mxCell>
        <mxCell id="b3-prep" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="👨‍💼 Chuẩn bị bài mẫu (Model Submission)&#xa;• 1–2 bài đại diện chất lượng&#xa;• Ghi điểm chuẩn mong muốn (hidden với judge)" vertex="1">
          <mxGeometry height="75" width="340" x="80" y="660" as="geometry" />
        </mxCell>
        <mxCell id="b3-score" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="⚖ Mỗi Judge chấm bài mẫu độc lập&#xa;• Score từng tiêu chí (0–10) + nhận xét&#xa;• Không trao đổi với judge khác" vertex="1">
          <mxGeometry height="75" width="340" x="460" y="660" as="geometry" />
        </mxCell>
        <mxCell id="b3-dash" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="🤖 Hiển thị Calibration Dashboard&#xa;┌───────────────────────────────────┐&#xa;│ Criteria  │Chuẩn│ J1 │ J2 │ J3  │&#xa;│Innovation │  8  │  8 │  7 │  9  │&#xa;│Technical  │  7  │  6 │  7 │  8  │&#xa;│Business   │  7  │  7 │  6 │  8  │&#xa;└───────────────────────────────────┘" vertex="1">
          <mxGeometry height="130" width="380" x="840" y="650" as="geometry" />
        </mxCell>
        <mxCell id="b4-discuss" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="B4 — 👨‍💼 + ⚖ Review Calibration&#xa;• Thảo luận sai lệch &gt; 2 điểm&#xa;• Đồng thuận cách diễn giải rubric&#xa;• &quot;Tại sao Judge X cho Innovation 9 khi chuẩn là 8?&quot;" vertex="1">
          <mxGeometry height="90" width="520" x="390" y="810" as="geometry" />
        </mxCell>
        <mxCell id="d-calib" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" value="Judges đạt&#xa;đồng thuận?" vertex="1">
          <mxGeometry height="90" width="220" x="590" y="940" as="geometry" />
        </mxCell>
        <mxCell id="b5-label" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=12;fontStyle=1;align=center;fontColor=#1b5e20;" value="━━━━━━━━━━━━━━━━━━━━━━━━━━━  OFFICIAL SCORING  ━━━━━━━━━━━━━━━━━━━━━━━━━━━" vertex="1">
          <mxGeometry height="25" width="1240" x="80" y="1065" as="geometry" />
        </mxCell>
        <mxCell id="b5" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" value="B5 — ⚖ Official Scoring — Chấm điểm chính thức&#xa;• 🤖 System unlock cổng chấm (đúng deadline)&#xa;• Judge xem repo + demo + slide&#xa;• Score từng tiêu chí (0–10) + nhận xét chi tiết&#xa;• Save Draft → Submit (lock sau submit, không sửa)" vertex="1">
          <mxGeometry height="110" width="620" x="390" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="b6" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="B6 — 🤖 Save Score &amp; Audit Log&#xa;• Lưu: judge_id | submission_id | criteria_id | score | comment | timestamp&#xa;• Audit: event_type=SCORE_SUBMITTED | append-only | không xóa" vertex="1">
          <mxGeometry height="90" width="620" x="390" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="d6-judge" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" value="Đủ judge&#xa;đã nộp?" vertex="1">
          <mxGeometry height="90" width="220" x="590" y="1385" as="geometry" />
        </mxCell>
        <mxCell id="remind-box" parent="1" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="🤖 Nhắc nhở judge chưa nộp&#xa;(24h trước deadline)" vertex="1">
          <mxGeometry height="55" width="250" x="1050" y="1400" as="geometry" />
        </mxCell>
        <mxCell id="b7" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="B7 — 🤖 Calculate Final Score&#xa;• Avg(score/tiêu chí) × weight → weighted total per submission&#xa;• Ví dụ: Innovation avg=8.0×25% + Technical avg=7.5×30% + ... = Final Score&#xa;• Tính phương sai (variance) điểm giữa các judges" vertex="1">
          <mxGeometry height="105" width="620" x="390" y="1525" as="geometry" />
        </mxCell>
        <mxCell id="d7-var" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" value="Variance &gt; 2&#xa;điểm?" vertex="1">
          <mxGeometry height="90" width="220" x="590" y="1675" as="geometry" />
        </mxCell>
        <mxCell id="b8-review" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="B8 — 👨‍💼 Review Variance&#xa;⚠️ Flag: cao nhất – thấp nhất &gt; 2 điểm&#xa;• Xem lại bài chấm của judge lệch&#xa;• Coaching / ghi chú bias&#xa;• Quyết định: giữ nguyên hoặc yêu cầu chấm lại&#xa;⚠️ Variance flag ≠ auto-loại (Rule ⑪)" vertex="1">
          <mxGeometry height="110" width="320" x="1030" y="1665" as="geometry" />
        </mxCell>
        <mxCell id="d8-ok" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="Kết quả&#xa;hợp lệ?" vertex="1">
          <mxGeometry height="80" width="180" x="1095" y="1820" as="geometry" />
        </mxCell>
        <mxCell id="b9" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="B9 — 🤖 Auto Ranking&#xa;• Sort by Final Score (descending) per hạng mục per vòng&#xa;• Rank trong hạng mục + Rank toàn sự kiện&#xa;• Dashboard công khai leaderboard (sau khi Coordinator publish)" vertex="1">
          <mxGeometry height="100" width="620" x="390" y="1825" as="geometry" />
